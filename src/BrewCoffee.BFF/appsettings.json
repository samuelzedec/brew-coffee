{
  "FrontendUrl": "https://localhost:4200",
  "Auth": {
    "Authority": "https://localhost:7295",
    "ReturnUrl": "https://localhost:4200/dashboard",
    "ClientId": "",
    "ClientSecret": ""
  },
  "ReverseProxy": {
    "Routes": {
      "brew-coffee-api": {
        "ClusterId": "brew-coffee-api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "brew-coffee-auth": {
        "ClusterId": "brew-coffee-auth",
        "Match": {
          "Path": "/account/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "brew-coffee-api": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7272"
          }
        }
      },
      "brew-coffee-auth": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7295"
          }
        }
      }
    }
  }
}