@page
@model BrewCoffee.Authorization.Pages.Login.IndexModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>BrewCoffee — Entrar</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&display=swap" rel="stylesheet"/>
    <style>
        * {
            font-family: 'Geist', sans-serif;
        }

        input:-webkit-autofill {
            -webkit-box-shadow: 0 0 0 30px #0a0a0a inset !important;
            -webkit-text-fill-color: #e5e5e5 !important;
        }
    </style>
</head>
<body class="bg-[#0a0a0a] text-[#e5e5e5] min-h-screen flex items-center justify-center px-4">

<div class="w-full max-w-sm">

    <div class="mb-10">
        <div class="flex items-center gap-2.5 mb-1">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 8h1a4 4 0 0 1 0 8h-1" stroke="#e5e5e5" stroke-width="1.5" stroke-linecap="round"
                      stroke-linejoin="round"/>
                <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z" stroke="#e5e5e5" stroke-width="1.5"
                      stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="6" y1="1" x2="6" y2="4" stroke="#e5e5e5" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="10" y1="1" x2="10" y2="4" stroke="#e5e5e5" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="14" y1="1" x2="14" y2="4" stroke="#e5e5e5" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="text-[15px] font-medium tracking-tight text-white">BrewCoffee</span>
        </div>
        <h1 class="text-2xl font-semibold tracking-tight text-white mt-6">Bem-vindo de volta</h1>
        <p class="text-sm text-[#737373] mt-1">Entre na sua conta para continuar</p>
    </div>

    @if (Model.ErrorMessage is not null)
    {
        <div
            class="mb-5 px-3.5 py-3 rounded-lg bg-[#1a0a0a] border border-[#3a1515] text-[#f87171] text-sm flex items-center gap-2.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10" stroke="#f87171" stroke-width="1.5"/>
                <line x1="12" y1="8" x2="12" y2="12" stroke="#f87171" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="12" cy="16" r="0.5" fill="#f87171" stroke="#f87171" stroke-width="1"/>
            </svg>
            @Model.ErrorMessage
        </div>
    }

    <form method="post" class="space-y-3">
        <input asp-for="ReturnUrl" type="hidden"/>

        <div>
            <label class="block text-xs font-medium text-[#a3a3a3] mb-1.5" for="Email">Email</label>
            <input asp-for="Email"
                   type="email"
                   id="Email"
                   placeholder="voce@exemplo.com"
                   autocomplete="email"
                   class="w-full bg-[#141414] border border-[#262626] rounded-lg px-3.5 py-2.5 text-sm text-[#e5e5e5] placeholder-[#404040] outline-none focus:border-[#404040] focus:ring-1 focus:ring-[#404040] transition-all"/>
        </div>

        <div>
            <label class="block text-xs font-medium text-[#a3a3a3]" for="Password">Senha</label>
            <input asp-for="Password"
                   type="password"
                   id="Password"
                   placeholder="••••••••"
                   autocomplete="current-password"
                   class="w-full bg-[#141414] border border-[#262626] rounded-lg px-3.5 py-2.5 text-sm text-[#e5e5e5] placeholder-[#404040] outline-none focus:border-[#404040] focus:ring-1 focus:ring-[#404040] transition-all"/>
        </div>

        <div class="flex items-center justify-between mb-1.5">
            <a href="/account/forgot-password" class="text-xs text-[#737373] hover:text-[#a3a3a3] transition-colors">Esqueceu?</a>
        </div>

        <button type="submit"
                class="w-full bg-white text-black text-sm font-medium rounded-lg py-2.5 mt-1 hover:bg-[#e5e5e5] active:bg-[#d4d4d4] transition-colors">
            Entrar
        </button>
    </form>

    <div class="flex items-center gap-3 my-5">
        <div class="flex-1 h-px bg-[#1f1f1f]"></div>
        <span class="text-xs text-[#404040]">ou continue com</span>
        <div class="flex-1 h-px bg-[#1f1f1f]"></div>
    </div>

    <div class="space-y-2.5">
        <a href="connect/external-login?provider=Google&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)"
           class="flex items-center justify-center gap-2.5 w-full bg-[#141414] border border-[#262626] rounded-lg py-2.5 text-sm text-[#e5e5e5] hover:bg-[#1a1a1a] hover:border-[#333] transition-all">
            <svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path
                    d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                    fill="#4285F4"/>
                <path
                    d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                    fill="#34A853"/>
                <path
                    d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                    fill="#FBBC05"/>
                <path
                    d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                    fill="#EA4335"/>
            </svg>
            Google
        </a>

        <a href="connect/external-login?provider=Microsoft&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)"
           class="flex items-center justify-center gap-2.5 w-full bg-[#141414] border border-[#262626] rounded-lg py-2.5 text-sm text-[#e5e5e5] hover:bg-[#1a1a1a] hover:border-[#333] transition-all">
            <svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M11.4 2H2v9.4h9.4V2z" fill="#f25022"/>
                <path d="M22 2h-9.4v9.4H22V2z" fill="#7fba00"/>
                <path d="M11.4 12.6H2V22h9.4v-9.4z" fill="#00a4ef"/>
                <path d="M22 12.6h-9.4V22H22v-9.4z" fill="#ffb900"/>
            </svg>
            Microsoft
        </a>
    </div>

    <p class="text-center text-xs text-[#525252] mt-8">
        Não tem uma conta?
        <a href="/register?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)" 
           class="text-[#a3a3a3] hover:text-white transition-colors">Criar conta</a>
    </p>

</div>

</body>
</html>