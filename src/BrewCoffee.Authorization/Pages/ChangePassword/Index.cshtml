@page
@model BrewCoffee.Authorization.Pages.ChangePassword.IndexModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BrewCoffee — Alterar senha</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Geist', sans-serif; }
        input:-webkit-autofill {
            -webkit-box-shadow: 0 0 0 30px #0a0a0a inset !important;
            -webkit-text-fill-color: #e5e5e5 !important;
        }
    </style>
</head>
<body class="bg-[#0a0a0a] text-[#e5e5e5] min-h-screen flex items-center justify-center px-4">

    <div class="w-full max-w-sm">

        <div class="mb-10">
            <div class="flex items-center gap-2.5 mb-1">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 8h1a4 4 0 0 1 0 8h-1" stroke="#e5e5e5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z" stroke="#e5e5e5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="6" y1="1" x2="6" y2="4" stroke="#e5e5e5" stroke-width="1.5" stroke-linecap="round"/>
                    <line x1="10" y1="1" x2="10" y2="4" stroke="#e5e5e5" stroke-width="1.5" stroke-linecap="round"/>
                    <line x1="14" y1="1" x2="14" y2="4" stroke="#e5e5e5" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <span class="text-[15px] font-medium tracking-tight text-white">BrewCoffee</span>
            </div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mt-6">Alterar senha</h1>
            <p class="text-sm text-[#737373] mt-1">Digite sua senha atual e escolha uma nova</p>
        </div>

        @if (Model.SuccessMessage is not null)
        {
            <div class="mb-5 px-3.5 py-3 rounded-lg bg-[#0a1a0a] border border-[#153515] text-[#4ade80] text-sm flex items-center gap-2.5">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="10" stroke="#4ade80" stroke-width="1.5"/>
                    <path d="M8 12l3 3 5-5" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                @Model.SuccessMessage
            </div>
        }

        @if (Model.ErrorMessage is not null)
        {
            <div class="mb-5 px-3.5 py-3 rounded-lg bg-[#1a0a0a] border border-[#3a1515] text-[#f87171] text-sm flex items-center gap-2.5">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="10" stroke="#f87171" stroke-width="1.5"/>
                    <line x1="12" y1="8" x2="12" y2="12" stroke="#f87171" stroke-width="1.5" stroke-linecap="round"/>
                    <circle cx="12" cy="16" r="0.5" fill="#f87171" stroke="#f87171" stroke-width="1"/>
                </svg>
                @Model.ErrorMessage
            </div>
        }

        <form method="post" class="space-y-3">

            <div>
                <label class="block text-xs font-medium text-[#a3a3a3] mb-1.5" for="CurrentPassword">Senha atual</label>
                <input asp-for="CurrentPassword"
                       type="password"
                       id="CurrentPassword"
                       placeholder="••••••••"
                       autocomplete="current-password"
                       class="w-full bg-[#141414] border border-[#262626] rounded-lg px-3.5 py-2.5 text-sm text-[#e5e5e5] placeholder-[#404040] outline-none focus:border-[#404040] focus:ring-1 focus:ring-[#404040] transition-all" />
            </div>

            <div>
                <label class="block text-xs font-medium text-[#a3a3a3] mb-1.5" for="NewPassword">Nova senha</label>
                <input asp-for="NewPassword"
                       type="password"
                       id="NewPassword"
                       placeholder="••••••••"
                       autocomplete="new-password"
                       class="w-full bg-[#141414] border border-[#262626] rounded-lg px-3.5 py-2.5 text-sm text-[#e5e5e5] placeholder-[#404040] outline-none focus:border-[#404040] focus:ring-1 focus:ring-[#404040] transition-all" />
            </div>

            <div>
                <label class="block text-xs font-medium text-[#a3a3a3] mb-1.5" for="ConfirmPassword">Confirmar nova senha</label>
                <input asp-for="ConfirmPassword"
                       type="password"
                       id="ConfirmPassword"
                       placeholder="••••••••"
                       autocomplete="new-password"
                       class="w-full bg-[#141414] border border-[#262626] rounded-lg px-3.5 py-2.5 text-sm text-[#e5e5e5] placeholder-[#404040] outline-none focus:border-[#404040] focus:ring-1 focus:ring-[#404040] transition-all" />
            </div>

            <button type="submit"
                    class="w-full bg-white text-black text-sm font-medium rounded-lg py-2.5 mt-1 hover:bg-[#e5e5e5] active:bg-[#d4d4d4] transition-colors">
                Alterar senha
            </button>

        </form>

        <p class="text-center text-xs text-[#525252] mt-8">
            <a href="javascript:history.back()" class="text-[#a3a3a3] hover:text-white transition-colors">← Voltar</a>
        </p>

    </div>

</body>
</html>